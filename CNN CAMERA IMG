import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from skimage import data, color, transform

#Load a built-in high quaity image (astronaut)
img_raw = data.camera()
img = transform.resize(img_raw, (224, 224))

plt.figure(figsize=(6, 6))
plt.imshow(img, cmap='grey')
plt.title("Input image: Ready for feature extraction")
plt.axis('off')
plt.show()


from skimage.color import rgb2gray
from scipy.signal import convolve2d

# img_raw is already grayscale, no need for rgb2gray conversion
img_gray = img_raw

# The 'neuron' filter (Sobel operator for vertical edges)
kernel = np.array([
    [-1, 0, 1],
    [-2, 0, 2],
    [-1, 0, 1]
])

# Simulating the Activation Map via convolution
feature_map = convolve2d(img_gray, kernel, mode='same')

# Display the result
plt.figure(figsize=(6, 6))
plt.imshow(np.absolute(feature_map), cmap='gray')
plt.title("Extracted Vertical Edges")
plt.axis('off')
plt.show()

import tensorflow as tf
from tensorflow.keras.applications.vgg16 import VGG16, preprocess_input
import numpy as np
import matplotlib.pyplot as plt
from skimage import color # Ensure color module is available for gray2rgb

model = VGG16(weights='imagenet', include_top=False)

# Prepare the Defender image for VGG16
# Convert grayscale image to RGB-like 3 channels before expanding dimensions
rgb_img = color.gray2rgb(img)
x = np.expand_dims(rgb_img * 255, axis=0)
x = preprocess_input(x)

# Extract mid-level Layer (Block 3, Conv 1)
mid_layer_model = tf.keras.Model(inputs=model.input, outputs=model.get_layer('block3_conv1').output)
mid_features = mid_layer_model.predict(x)

# Visualize the 10th and 15th filters (neurons)
fig, ax = plt.subplots(1, 2, figsize=(12, 6))
ax[0].imshow(mid_features[0, :, :, 10], cmap='viridis')
ax[0].set_title('Neuron 10')
ax[1].imshow(mid_features[0, :, :, 15], cmap='viridis')
ax[1].set_title('Neuron 15')
plt.show()
